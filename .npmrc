# https://docs.npmjs.com/cli/v11/using-npm/config
# https://docs.npmjs.com/cli/v11/using-npm/changelog
# https://github.com/npm/cli/releases
#  https://github.com/npm/cli/releases/tag/v11.17.0

# install-strategy = nested
# allow-git = root

# Do not allow npm to install peerDependencies outside specified range
strict-peer-deps = true

# Use ~ version specifier for newly added dependencies
save-prefix = ~

# Don not run any lifecycle (pre/post/prepare and etc.) scripts
ignore-scripts = true

# Do not show message about dependencies looking for funding
fund = false

# Do not install packages younger then 3 days
min-release-age = 3

# Limits the ability for npm to install dependencies from directories. That is,
#  dependencies that point to a directory instead of a version or semver range.
allow-directory = root

# Limits the ability for npm to install dependencies from tarball files. That
#  is, dependencies that point to a local tarball file instead of a version or
#  semver range.
allow-file = root

# Limits the ability for npm to fetch dependencies from git references. That is,
#  dependencies that point to a git repo instead of a version or semver range.
allow-git = root

# Limits the ability for npm to fetch dependencies from urls. That is,
#  dependencies that point to a tarball url instead of a version or semver range.
allow-remote = root
